# Copy this file to .env and fill in real values.
# .env is gitignored — never commit secrets.

# ---- REST API (csith) ----
CSITH_BASE_URL=http://cli.csith.com
CSITH_API_KEY=your-x-api-key-here
CSITH_TOKEN_PATH=/api/system/token
# Business selector — list comes from this endpoint; selected bizId saved here:
CSITH_BIZ_LIST_PATH=/Services/Administration/CsPara/GetList
CSITH_BIZ_ID=
# Shop list endpoint (called as ?BizId=<CSITH_BIZ_ID>):
CSITH_SHOP_LIST_PATH=/Services/Geniuz/Shop/GetShopList
# Product list endpoint — POST { Fg, SearchCode, BizId }. Fg=0 = all, Fg=22 = PO lines.
CSITH_PRODUCTS_PATH=/Services/Geniuz/BarCode/GetBarCode
# Purchase order list endpoint — POST { DocFg, Fg, SearchCode, BizId }
CSITH_PUR_INVOICE_PATH=/Services/Geniuz/BarCode/GetPurInvoice
# If the list is nested, e.g. {"data":[...]}, set the array path (dot notation):
CSITH_PRODUCTS_ARRAY_PATH=

# Field mapping — JSON key(s) -> label field. Comma = fallback order.
MAP_SKU=skuCode
MAP_NAME=skuDesc,pluDesc
MAP_PRICE=sellUnitPrice1,price
MAP_BARCODE=pluCode,barcode
MAP_UNIT=sellUnit,stkUnit

# ---- SQL Server (GeniuzPOS) — requires: npm install mssql ----
SQL_HOST=
SQL_PORT=1433
SQL_DATABASE=
SQL_USER=
SQL_PASSWORD=
SQL_ENCRYPT=false
SQL_TRUST_CERT=true
# โหมดแหล่งข้อมูล: api (REST) หรือ sql (SQL Server) — สลับได้จากหน้า "ตั้งค่าเชื่อมต่อ"
DATA_SOURCE=api
# SQL queries — ค่าเริ่มต้นชี้ไปที่ฟังก์ชัน/ตารางของ GeniuzPOS (ปรับได้). param: @fg @code @bizId @docFg
# คอลัมน์ผลลัพธ์อ่านแบบ case-insensitive (วาง SQL ดิบได้ ไม่ต้อง AS alias)
# SQL_BIZ_QUERY=SELECT BizId, BizCode, BizName, TaxInvName, TaxInvAddrLine1 FROM csPara ORDER BY BizId
# SQL_SHOP_QUERY=SELECT ShopId, ShopName, ShopNameEn, BranchName, ShopAddress, ShopTaxId, ShopRegName, ShopRegAddressLine1 FROM dbo.psShop WHERE BizId=@bizId AND IsActive=1
# SQL_QUERY=SELECT * FROM dbo.csbarcode_GetSkuPluInfo(@fg, @code, @bizId)
# SQL_PO_QUERY=SELECT * FROM dbo.csbarcode_GetPurInvoice(@fg, @code, @bizId, @docFg)

# ---- server ----
PORT=8080
