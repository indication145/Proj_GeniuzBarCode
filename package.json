{
  "name": "geniuzbarcode-label-designer",
  "version": "0.1.0",
  "private": true,
  "description": "GeniuzBarCode Label Designer — local server + data proxy",
  "bin": "server.js",
  "scripts": {
    "start": "node server.js",
    "build:exe": "pkg . --targets node22-win-x64 --output dist/LabelDesigner.exe"
  },
  "pkg": {
    "assets": [
      "LabelDesigner.dc.html",
      "support.js",
      "index.html"
    ],
    "outputPath": "dist"
  },
  "optionalDependencies": {
    "mssql": "^11.0.1"
  },
  "devDependencies": {
    "@yao-pkg/pkg": "^6.3.0"
  }
}
