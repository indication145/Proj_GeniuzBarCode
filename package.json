{
  "name": "geniuzbarcode-label-designer",
  "version": "0.1.0",
  "private": true,
  "description": "GeniuzBarCode Label Designer — local server + data proxy",
  "bin": "server.js",
  "scripts": {
    "start": "node server.js",
    "build:web": "npm --prefix web run build",
    "build:exe": "node scripts/build-exe.js",
    "dev:web": "npm --prefix web run dev"
  },
  "pkg": {
    "assets": [
      "web/dist/**/*"
    ],
    "outputPath": "dist"
  },
  "optionalDependencies": {
    "mssql": "^11.0.1"
  },
  "devDependencies": {
    "@yao-pkg/pkg": "^6.3.0",
    "png-to-ico": "^3.0.1",
    "rcedit": "^5.0.2"
  }
}
